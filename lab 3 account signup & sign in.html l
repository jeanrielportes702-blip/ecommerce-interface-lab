<!-- Separate HTML and CSS, with responsive header and footer, applying the 7 tasks -->

<!-- HTML -->
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>ShopEase - Sign Up</title>
<link rel="stylesheet" href="accountsignup.css" />
</head>
<body>

<header>
  <h1 style="margin:0; color:white;">ShopEase</h1>
  <nav>
    <ul>
      <li><a href="#">Home</a></li>
      <li><a href="#">Shop</a></li>
      <li><a href="#">Contact</a></li>
    </ul>
  </nav>
</header>

<div class="signup-container">
  <h1>Create Account</h1>
  <form action="account.html" method="post">
    <label for="fullname">Full Name</label>
    <input type="text" id="fullname" name="fullname" required />

    <label for="email">Email Address</label>
    <input type="email" id="email" name="email" required />

    <label for="password">Password</label>
    <input type="password" id="password" name="password" minlength="6" required />

    <label for="confirm">Confirm Password</label>
    <input type="password" id="confirm" name="confirm" minlength="6" required />

    <button type="submit">Sign Up</button>
  </form>
  <div class="login-link">
    <p>Already have an account? <a href="landing.html">Log in</a></p>
  </div>
</div>

<footer>
  <p>&copy; 2026 ShopEase. All Rights Reserved.</p>
</footer>

</body>
</html>
